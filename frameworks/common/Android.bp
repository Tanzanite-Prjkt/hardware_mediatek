java_library {
    name: "mediatek-common",
    system_ext_specific: true,
    installable: true,

    srcs: [
        "src/**/*.java",
    ],

    required: ["mediatek-common.xml"],
}

prebuilt_etc {
    name: "mediatek-common.xml",
    src: "mediatek-common.xml",
    sub_dir: "permissions",
    system_ext_specific: true,
}
